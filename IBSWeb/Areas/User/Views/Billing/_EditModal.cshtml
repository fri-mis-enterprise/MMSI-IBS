@model CreateBillingViewModel

<style>
    #billingModal .modal-dialog {
        max-width: 95% !important;
        width: 95% !important;
        max-height: 95vh;
        margin: 2.5vh auto;
    }
    #billingModal .modal-content {
        max-height: 95vh;
        display: flex;
        flex-direction: column;
    }
    #billingModal .modal-body {
        overflow-y: auto;
        max-height: calc(95vh - 140px);
    }
</style>

<div class="modal-header bg-secondary">
    <h5 class="modal-title text-white">Edit Billing #@Model.MMSIBillingNumber</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<form id="billingEditForm" method="post">
    @Html.AntiForgeryToken()
    <input asp-for="MMSIBillingId" id="billingId" value="@Model.MMSIBillingId" type="hidden">
    <input type="hidden" asp-for="IsUndocumented" value="@Model.IsUndocumented" />

    <div class="modal-body p-4">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- Customer Selection (Full Width, Read-only) -->
        <div class="mb-3">
            <label class="form-label fw-bold">Customer</label>
            <div class="input-group">
                <span class="input-group-text bg-light"><i class="bi bi-person text-muted"></i></span>
                <input type="text" class="form-control bg-light" value="@(Model.Customers?.FirstOrDefault(c => c.Value == Model.CustomerId.ToString())?.Text ?? "")" readonly>
                <input type="hidden" asp-for="CustomerId" id="CustomerId" />
                <div class="input-group-text @(ViewData["HasPrincipal"] as bool? == true ? "" : "d-none") bg-light" id="PrincipalCheckboxContainer">
                    <input class="form-check-input mt-0 me-1" type="checkbox" id="UsePrincipalCheckbox" @(Model.PrincipalId.HasValue ? "checked" : "")>
                    <label class="small mb-0" for="UsePrincipalCheckbox" style="white-space: nowrap;">Bill to Principal</label>
                </div>
            </div>
        </div>

        <!-- Customer Details Display -->
        <div id="CustomerDetailsSection" class="mb-3">
            <div class="card border-0 bg-light">
                <div class="card-body py-2">
                    <div class="row g-2 small">
                        <div class="col-md-6">
                            <span class="text-muted">Address:</span>
                            <span id="CustomerAddress" class="fw-semibold ms-1">@(ViewData["CustomerAddress"] ?? "-")</span>
                        </div>
                        <div class="col-md-3">
                            <span class="text-muted">TIN:</span>
                            <span id="CustomerTIN" class="fw-semibold ms-1">@(ViewData["CustomerTIN"] ?? "-")</span>
                        </div>
                        <div class="col-md-3">
                            <span class="text-muted">Terms:</span>
                            <span id="CustomerTerms" class="fw-semibold ms-1">@(ViewData["CustomerTerms"] ?? "-")</span>
                        </div>
                        <div class="col-md-6">
                            <span class="text-muted">Business Style:</span>
                            <span id="CustomerBusinessStyle" class="fw-semibold ms-1">@(ViewData["CustomerBusinessStyle"] ?? "-")</span>
                        </div>
                        <div class="col-md-3">
                            <span class="text-muted">VAT Type:</span>
                            <span id="CustomerVatType" class="fw-semibold ms-1">@(ViewData["CustomerVatType"] ?? "-")</span>
                        </div>
                        <div class="col-md-3">
                            <span class="text-muted">Type:</span>
                            <span id="CustomerType" class="fw-semibold ms-1">@(ViewData["CustomerType"] ?? "-")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Principal Section (Inline) -->
        <div class="row g-3 mb-3 @(Model.PrincipalId.HasValue ? "" : "d-none")" id="PrincipalSection">
            <div class="col-md-7 position-relative">
                <label class="form-label fw-bold small">Principal</label>
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="PrincipalSearch" class="form-control" placeholder="Type to search principals..." value="@(Model.CustomerPrincipal?.FirstOrDefault(p => p.Value == Model.PrincipalId?.ToString())?.Text ?? "")" autocomplete="off">
                    <input type="hidden" asp-for="PrincipalId" id="PrincipalId" />
                </div>
                <div id="PrincipalSearchResults" class="list-group position-absolute w-100 shadow-sm border" style="z-index: 1050; max-height: 200px; overflow-y: auto; top: 100%;"></div>
            </div>
            <div class="col-md-5 d-flex align-items-end">
                <div class="@(Model.PrincipalId.HasValue ? "" : "d-none") w-100" id="BilledToContainer">
                    <label class="form-label fw-bold small d-block">Billed To</label>
                    <div class="btn-group w-100" role="group">
                        <input type="radio" class="btn-check" asp-for="BilledTo" value="LOCAL" id="billLocal" checked autocomplete="off">
                        <label class="btn btn-outline-primary" for="billLocal">Local</label>
                        <input type="radio" class="btn-check" asp-for="BilledTo" value="PRINCIPAL" id="billPrincipal" autocomplete="off">
                        <label class="btn btn-outline-primary" for="billPrincipal">Principal</label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Two Column Layout -->
        <div class="row g-3">
            <!-- Left Column: Billing Configuration -->
            <div class="col-12 col-lg-4">
                <div class="card h-100 border-0 bg-light">
                    <div class="card-header bg-transparent border-0 py-2">
                        <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-receipt me-2"></i>Billing Details</h6>
                    </div>
                    <div class="card-body pt-0">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-bold">Billing Number</label>
                                <input asp-for="MMSIBillingNumber" type="text" class="form-control bg-light" readonly value="@Model.MMSIBillingNumber">
                                <span asp-validation-for="MMSIBillingNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-12 col-md-6">
                                <label asp-for="VoyageNumber" class="form-label fw-bold">Voyage Number <span class="text-danger">*</span></label>
                                <input asp-for="VoyageNumber" type="text" class="form-control" id="VoyageNumber" required>
                                <span asp-validation-for="VoyageNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-12 col-md-6">
                                <label asp-for="Date" class="form-label fw-bold">Date</label>
                                <input asp-for="Date" type="date" class="form-control" id="Date">
                                <span asp-validation-for="Date" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="PortId" class="form-label fw-bold">Port <span class="text-danger">*</span></label>
                                <select asp-for="PortId" asp-items="@Model.Ports" id="PortSelect" class="form-select js-select2" required style="width: 100%;">
                                    <option value="">-- Select Port --</option>
                                </select>
                                <span asp-validation-for="PortId" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="TerminalId" class="form-label fw-bold">Terminal <span class="text-danger">*</span></label>
                                <select asp-for="TerminalId" asp-items="@Model.Terminals" id="TerminalSelect" class="form-select js-select2" required style="width: 100%;">
                                    <option value="">-- Select Terminal --</option>
                                </select>
                                <span asp-validation-for="TerminalId" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="VesselId" class="form-label fw-bold">Vessel <span class="text-danger">*</span></label>
                                <select asp-for="VesselId" asp-items="@Model.Vessels" class="form-select js-select2" required style="width: 100%;">
                                    <option value="">-- Select Vessel --</option>
                                </select>
                                <span asp-validation-for="VesselId" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="ApOtherTug" class="form-label fw-bold">AP Other Tug</label>
                                <input asp-for="ApOtherTug" step="0.01" type="number" class="form-control" min="0" placeholder="0.00">
                                <span asp-validation-for="ApOtherTug" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Job Order & Ticket Selection -->
            <div class="col-12 col-lg-8">
                <div class="card h-100 border-0">
                    <div class="card-header bg-transparent border-0 py-2 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-briefcase me-2"></i>Job Order & Dispatch Tickets</h6>
                        <span class="badge bg-info" id="selectedTicketCount">0 selected</span>
                    </div>
                    <div class="card-body pt-0">
                        <!-- Job Order Search -->
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Select Job Order</label>
                            <div class="position-relative">
                                <input type="text" id="JobOrderSearch" class="form-control form-control-sm" placeholder="Search job order number..." autocomplete="off" disabled>
                                <input type="hidden" asp-for="JobOrderId" id="JobOrderId" />
                                <div id="JobOrderSearchResults" class="list-group position-absolute w-100 shadow-sm d-none" style="z-index: 1000; max-height: 200px; overflow-y: auto;"></div>
                            </div>
                            <small class="text-muted">Select a job order to load its dispatch tickets</small>
                        </div>

                        <!-- Tickets Table with Checkboxes -->
                        <div class="table-responsive" style="max-height: 250px;">
                            <table id="ticketsTable" class="table table-sm table-hover mb-0" style="font-size: 0.75rem;">
                                <thead class="table-light">
                                    <tr>
                                        <th class="text-center" style="width: 30px;">
                                            <input type="checkbox" id="selectAllTickets" class="form-check-input">
                                        </th>
                                        <th class="text-center">Dispatch#</th>
                                        <th class="text-center">Tugboat</th>
                                        <th class="text-center">Service</th>
                                        <th class="text-center">Hours</th>
                                        <th class="text-end">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="text-muted">
                                        <td colspan="6" class="text-center py-3">
                                            <em>Select a customer and job order to view tickets</em>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Hidden select for form submission -->
                        <select asp-for="ToBillDispatchTickets" id="DispatchTicketSelect" name="ToBillDispatchTickets" multiple="multiple" class="d-none">
                        </select>

                        <div class="alert alert-light border mt-2 mb-0 py-2">
                            <div class="row text-center small">
                                <div class="col-4">
                                    <span class="text-muted">Dispatch:</span><br>
                                    <strong class="text-primary">₱<span id="DispatchAmountTotal">0.00</span></strong>
                                </div>
                                <div class="col-4 border-start">
                                    <span class="text-muted">BAF:</span><br>
                                    <strong class="text-primary">₱<span id="BAFAmountTotal">0.00</span></strong>
                                </div>
                                <div class="col-4 border-start">
                                    <span class="text-muted">Total:</span><br>
                                    <strong class="text-success fs-6">₱<span id="OverallTotal">0.00</span></strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-footer bg-light">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </button>
        <button type="button" class="btn btn-primary btn-sm" id="submitEditBilling">
            <i class="bi bi-save me-1"></i>Save Changes
        </button>
    </div>
</form>

<script>
    $(document).ready(function () {
        let multiSelectVar = $('.js-example-basic-multiple');
        multiSelectVar.select2({ dropdownParent: $('#billingModal') });
        $('#billingModal .js-select2').select2({ dropdownParent: $('#billingModal') });

        let table = initializeDataTable('#dataTable');
        const currentCustomerId = $("#CustomerId").val();

        setupEventListeners();
        fillDataOnStartup();

        function initializeDataTable(selector) {
            if ($.fn.DataTable.isDataTable(selector)) {
                $(selector).DataTable().destroy();
            }
            return $(selector).DataTable({
                paging: false, info: false, order: [[0, 'asc']],
                lengthChange: false, searching: false
            });
        }

        function setupEventListeners() {
            $("#UsePrincipalCheckbox").on("change", handleUsePrincipalChange);
            $("#PortSelect").on("change", handlePortChange);
            $("#submitEditBilling").on("click", areYouSureToBill);
            multiSelectVar.on('change', handleDispatchTicketsChange);
        }

        function fillDataOnStartup() {
            $("#JobOrderSearch").prop('disabled', false);
            handleDispatchTicketsChange();
        }

        function handleUsePrincipalChange() {
            const isChecked = $("#UsePrincipalCheckbox").is(":checked");
            if (isChecked) {
                $("#PrincipalSection").removeClass("d-none");
                $("#BilledToContainer").removeClass("d-none");
                setTimeout(() => $("#PrincipalSearch").focus(), 100);
            } else {
                $("#PrincipalSection").addClass("d-none");
                $("#PrincipalSearch").val("");
                $("#PrincipalId").val("");
                $("#BilledToContainer").addClass("d-none");
                $("#billLocal").prop("checked", true);
            }
        }

        // ── Principal search ─────────────────────────────────────────────
        let principalSearchTimeout;
        const $principalSearch = $("#PrincipalSearch");
        const $principalResults = $("#PrincipalSearchResults");
        const $principalId = $("#PrincipalId");

        async function performPrincipalSearch(searchTerm) {
            if (!currentCustomerId) return;
            try {
                const params = new URLSearchParams({ customerId: currentCustomerId });
                if (searchTerm.length) params.set('term', searchTerm);
                const res = await fetch(`@Url.Action("SearchPrincipals", "Billing", new { area = "User" })?${params}`);
                const data = await res.json();
                $principalResults.empty();
                if (Array.isArray(data) && data.length > 0) {
                    data.forEach(item => {
                        $principalResults.append(
                            $('<a href="#" class="list-group-item list-group-item-action py-2">')
                                .data('principal', item)
                                .html(`<span>${item.name}</span>`)
                        );
                    });
                } else {
                    $principalResults.append($('<div class="list-group-item py-2 text-muted"><em>No principals found</em></div>'));
                }
                $principalResults.removeClass('d-none');
            } catch {
                $principalResults.empty().addClass('d-none');
            }
        }

        $principalSearch.on('input', function () {
            clearTimeout(principalSearchTimeout);
            const searchTerm = $(this).val().trim();
            if (!searchTerm.length) { $principalResults.empty().addClass('d-none'); $principalId.val(''); return; }
            if (searchTerm.length === 1) performPrincipalSearch(searchTerm);
            else principalSearchTimeout = setTimeout(() => performPrincipalSearch(searchTerm), 150);
        });

        $principalSearch.on('focus', function () {
            performPrincipalSearch($(this).val().trim());
        });

        $principalSearch.on('keydown', function (e) {
            const $items = $principalResults.find('a');
            const $active = $items.filter('.active');
            if (e.key === 'ArrowDown') { e.preventDefault(); ($active.length ? $active.removeClass('active').next() : $items.first()).addClass('active'); }
            else if (e.key === 'ArrowUp') { e.preventDefault(); ($active.length ? $active.removeClass('active').prev() : $items.last()).addClass('active'); }
            else if (e.key === 'Enter') { e.preventDefault(); $active.trigger('click'); }
            else if (e.key === 'Escape') { $principalResults.addClass('d-none'); }
        });

        $principalResults.on('click', 'a', function (e) {
            e.preventDefault();
            const principal = $(this).data('principal');
            $principalSearch.val(principal.name);
            $principalId.val(principal.value);
            $principalResults.empty().addClass('d-none');
        });

        $(document).on('click', function (e) {
            if (!$(e.target).closest('#PrincipalSearch, #PrincipalSearchResults').length) {
                $principalResults.empty().addClass('d-none');
            }
        });

        // ── Job Order search ─────────────────────────────────────────────
        let jobOrderSearchTimeout;
        const $jobOrderSearch = $("#JobOrderSearch");
        const $jobOrderResults = $("#JobOrderSearchResults");
        const $jobOrderId = $("#JobOrderId");
        const $ticketsTableBody = $("#ticketsTable tbody");
        const $dispatchSelect = $("#DispatchTicketSelect");

        async function performJobOrderSearch(searchTerm) {
            if (!currentCustomerId) return;
            try {
                const res = await fetch(`@Url.Action("SearchJobOrders", "Billing", new { area = "User" })?customerId=${encodeURIComponent(currentCustomerId)}&term=${encodeURIComponent(searchTerm)}`);
                const data = await res.json();
                $jobOrderResults.empty();
                if (Array.isArray(data) && data.length > 0) {
                    data.forEach(item => {
                        $jobOrderResults.append(
                            $('<a href="#" class="list-group-item list-group-item-action py-2">')
                                .data('jobOrder', item)
                                .html(`<strong>${item.name}</strong><br><small class="text-muted">${item.description || ''}</small>`)
                        );
                    });
                } else {
                    $jobOrderResults.append($('<div class="list-group-item py-2 text-muted"><em>No job orders found</em></div>'));
                }
                $jobOrderResults.removeClass('d-none');
            } catch {
                $jobOrderResults.empty().addClass('d-none');
            }
        }

        $jobOrderSearch.on('input', function () {
            clearTimeout(jobOrderSearchTimeout);
            const searchTerm = $(this).val().trim();
            if (!searchTerm.length) { $jobOrderResults.empty().addClass('d-none'); return; }
            jobOrderSearchTimeout = setTimeout(() => performJobOrderSearch(searchTerm), 150);
        });

        $jobOrderResults.on('click', 'a', async function (e) {
            e.preventDefault();
            const jobOrder = $(this).data('jobOrder');
            $jobOrderSearch.val(jobOrder.name);
            $jobOrderId.val(jobOrder.value);
            $jobOrderResults.empty().addClass('d-none');
            try {
                const res = await fetch(`@Url.Action("GetDispatchTicketsByJobOrder", "Billing", new { area = "User" })?jobOrderId=${encodeURIComponent(jobOrder.value)}`);
                renderTicketsTable(await res.json());
            } catch {
                $ticketsTableBody.html('<tr class="text-danger"><td colspan="6" class="text-center py-3"><em>Error loading tickets</em></td></tr>');
            }
        });

        function renderTicketsTable(tickets) {
            $ticketsTableBody.empty();
            $dispatchSelect.empty();
            if (!tickets?.length) {
                $ticketsTableBody.html('<tr class="text-muted"><td colspan="6" class="text-center py-3"><em>No tickets available for billing in this job order</em></td></tr>');
                updateTotals();
                return;
            }
            tickets.forEach(ticket => {
                $ticketsTableBody.append(`
                <tr data-ticket-id="${ticket.dispatchTicketId}">
                    <td class="text-center"><input type="checkbox" class="form-check-input ticket-checkbox" value="${ticket.dispatchTicketId}" checked></td>
                    <td class="text-center">${ticket.dispatchNo}</td>
                    <td class="text-center">${ticket.tugboat}</td>
                    <td class="text-center">${ticket.service}</td>
                    <td class="text-center">${ticket.duration}</td>
                    <td class="text-end">${formatNumber(ticket.totalAmount)}</td>
                </tr>
            `);
                $dispatchSelect.append($('<option>').val(ticket.dispatchTicketId).text(ticket.dispatchNo).prop('selected', true));
            });
            updateTotals();
        }

        $ticketsTableBody.on('change', '.ticket-checkbox', function () {
            const ticketId = $(this).val();
            const $option = $dispatchSelect.find(`option[value="${ticketId}"]`);
            if ($(this).is(':checked')) {
                if (!$option.length) $dispatchSelect.append($('<option>').val(ticketId).prop('selected', true));
                else $option.prop('selected', true);
            } else {
                $option.prop('selected', false);
            }
            updateTotals();
        });

        $('#selectAllTickets').on('change', function () {
            $ticketsTableBody.find('.ticket-checkbox').prop('checked', $(this).is(':checked')).trigger('change');
        });

        function updateTotals() {
            let dispatch = 0, baf = 0;
            $ticketsTableBody.find('.ticket-checkbox:checked').each(function () {
                const total = parseFloat($(this).closest('tr').find('td:eq(5)').text().replace(/[^0-9.-]+/g, '')) || 0;
                dispatch += total * 0.8;
                baf += total * 0.2;
            });
            const count = $ticketsTableBody.find('.ticket-checkbox:checked').length;
            $('#DispatchAmountTotal').text(formatNumber(dispatch));
            $('#BAFAmountTotal').text(formatNumber(baf));
            $('#OverallTotal').text(formatNumber(dispatch + baf));
            $('#selectedTicketCount').text(`${count} selected`);
        }

        // ── Port → Terminal cascade ──────────────────────────────────────
        async function handlePortChange() {
            try {
                const res = await fetch(`@Url.Action("ChangeTerminal", "DispatchTicket", new { area = "User" })?portId=${encodeURIComponent($("#PortSelect").val())}`);
                const data = await res.json();
                const $terminalSelect = $("#TerminalSelect");
                $terminalSelect.empty().append('<option value="">Select Terminal</option>');
                if (Array.isArray(data)) data.forEach(item => $terminalSelect.append($('<option>').val(item.value).text(item.text)));
            } catch {
                console.error('Failed to load terminals');
            }
        }

        // ── Dispatch tickets change ──────────────────────────────────────
        async function handleDispatchTicketsChange() {
            const selectedTickets = multiSelectVar.val();
            $('#selectedTicketCount').text(`${selectedTickets?.length || 0} selected`);
            if (!selectedTickets?.length) { updateDispatchTable([]); return; }
            try {
                const body = selectedTickets.map(id => `dispatchTicketIds=${encodeURIComponent(id)}`).join('&');
                const res = await fetch('@Url.Action("GetDispatchTickets", "Billing", new { area = "User" })', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body
                });
                updateDispatchTable((await res.json()).data);
            } catch {
                console.error('Failed to load dispatch tickets');
            }
        }

        function updateDispatchTable(data) {
            let totalDispatch = 0, totalBAF = 0;
            table.destroy();
            const $tbody = $('#dataTable tbody').empty();
            (data || []).forEach(value => {
                totalDispatch += value.dispatchNetRevenue;
                totalBAF += value.bafNetRevenue;
                $tbody.append(`
                <tr>
                    <td class="text-center">${value.dispatchNumber}</td>
                    <td class="text-center">${value.tugboat?.tugboatName || '-'}</td>
                    <td class="text-center">${value.service?.serviceName || '-'}</td>
                    <td class="text-center">${(value.totalHours || 0).toFixed(2)}</td>
                    <td class="text-end">₱${formatNumber(value.dispatchNetRevenue + value.bafNetRevenue)}</td>
                </tr>
            `);
            });
            $("#DispatchAmountTotal").text(formatNumber(totalDispatch));
            $("#BAFAmountTotal").text(formatNumber(totalBAF));
            $("#OverallTotal").text(formatNumber(totalDispatch + totalBAF));
            $('#selectedTicketCount').text(`${data?.length || 0} selected`);
            table = initializeDataTable('#dataTable');
        }

        // ── Submit ───────────────────────────────────────────────────────
        function areYouSureToBill(event) {
            event.preventDefault();
            const form = document.getElementById("billingEditForm");
            if (!form.checkValidity()) { form.reportValidity(); return; }
            if (!$("#DispatchTicketSelect").val()?.length) {
                Swal.fire({ title: "No Tickets Selected", text: "Please select at least one dispatch ticket to bill.", icon: "warning" });
                return;
            }
            Swal.fire({ title: "Save changes to this billing?", text: "You can edit this again before posting.", showCancelButton: true, confirmButtonText: "Yes", cancelButtonText: "No" })
                .then(result => { if (result.isConfirmed) submitEditForm(); });
        }

        async function submitEditForm() {
            try {
                const res = await fetch('@Url.Action("Edit", "Billing", new { area = "User" })', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams(new FormData(document.getElementById('billingEditForm'))).toString()
                });
                const response = await res.json();
                if (response.success) {
                    $('#billingModal').modal('hide');
                    Swal.fire({ title: "Success!", text: response.message, icon: "success" })
                        .then(() => response.redirectUrl ? window.location.href = response.redirectUrl : location.reload());
                } else {
                    Swal.fire({ title: "Error", text: response.message || "Failed to update billing.", icon: "error" });
                }
            } catch {
                Swal.fire({ title: "Error", text: "An error occurred while updating the billing.", icon: "error" });
            }
        }
    });
</script>
