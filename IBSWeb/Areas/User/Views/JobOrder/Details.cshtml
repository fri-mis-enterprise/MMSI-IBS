@model IBS.Models.MMSI.JobOrder

@{
    ViewData["Title"] = $"Job Order {Model.JobOrderNumber}";
}

<link rel="stylesheet" href="~/css/index-style.css">

<style>
    .sticky-panel {
        position: sticky;
        top: 20px;
        max-height: calc(100vh - 150px);
        overflow-y: auto;
    }

    .badge.bg-orange {
        background-color: #fd7e14 !important;
        color: #4A1B0C !important;
    }
</style>

<div class="container-fluid mt-4">
    <!-- Header Card -->
    <div class="card shadow border-0 mb-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center p-3">
            <h5 class="m-0"><i class="bi bi-folder2-open"></i> @Model.JobOrderNumber</h5>
            <div class="d-flex gap-2">
                @if (Model.Status == "Open")
                {
                    <button type="button" class="btn btn-warning" onclick="confirmClose()">
                        <i class="bi bi-lock"></i> Close Job Order
                    </button>
                    <form asp-action="Close" asp-route-id="@Model.JobOrderId" method="post" id="closeForm" class="d-none"></form>
                }
                <button type="button" class="btn btn-light" onclick="openEditJobOrderModal(PageConfig.jobOrderId, PageConfig.hasTickets)">
                    <i class="bi bi-pencil"></i> Edit Details
                </button>
                @if (Model.Status == "Open" && User.IsInRole("Admin"))
                {
                    <button type="button" class="btn btn-outline-danger" onclick="confirmCancel()">
                        <i class="bi bi-slash-circle"></i> Cancel
                    </button>
                    <form asp-action="Cancel" asp-route-id="@Model.JobOrderId" method="post" id="cancelForm" class="d-none"></form>
                }
                <a asp-action="Index" class="btn btn-outline-light">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>

    <!-- 2-Panel Layout -->
    <div class="row g-4">
        <!-- Left Panel: Job Order Details (35%) -->
        <div class="col-lg-4 col-md-5">
            <div class="card shadow border-0 sticky-panel">
                <div class="card-header bg-primary text-white p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="m-0"><i class="bi bi-info-circle me-2"></i>Job Order Details</h6>
                        </div>
                        <span class="badge @(Model.Status == "Open" ? "bg-success" : "bg-secondary") fs-6">@Model.Status</span>
                    </div>
                </div>
                <div class="card-body p-3">
                    <!-- Job Order Information -->
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="text-muted small mb-1">Date</label>
                            <div class="fw-bold">@Model.Date.ToString("MMM dd, yyyy")</div>
                        </div>
                    </div>

                    <hr class="my-2">

                    <!-- Customer & Vessel -->
                    <div class="row g-3 mb-3">
                        <div class="col-12">
                            <label class="text-muted small mb-1">Customer</label>
                            <div class="fw-bold">@Model.Customer!.CustomerName</div>
                        </div>
                        <div class="col-12">
                            <label class="text-muted small mb-1">Vessel</label>
                            <div class="fw-bold">@Model.Vessel!.VesselName</div>
                        </div>
                    </div>

                    <hr class="my-2">

                    <!-- Location -->
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="text-muted small mb-1">Port</label>
                            <div>@(Model.Port!.PortName ?? "-")</div>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small mb-1">Terminal</label>
                            <div>@(Model.Terminal!.TerminalName ?? "-")</div>
                        </div>
                    </div>

                    <hr class="my-2">

                    <!-- Voyage Details -->
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="text-muted small mb-1">COS #</label>
                            <div>@(Model.COSNumber ?? "-")</div>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small mb-1">Voyage #</label>
                            <div>@(Model.VoyageNumber ?? "-")</div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Remarks))
                    {
                        <hr class="my-3">
                        <div>
                            <label class="text-muted small mb-1"><i class="bi bi-chat-left-text me-1"></i>Remarks</label>
                            <p class="mb-0 small text-muted">@Model.Remarks</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Panel: Dispatch Tickets (65%) -->
        <div class="col-lg-8 col-md-7">
            <div class="card shadow border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center p-3">
                    <h5 class="m-0 text-primary"><i class="bi bi-list-task me-2"></i>Dispatch Tickets</h5>
                    @if (Model.Status == "Open")
                    {
                        <button type="button" class="btn btn-primary" onclick="openDispatchTicketModal()">
                            <i class="bi bi-plus-circle"></i> Add Ticket
                        </button>
                    }
                </div>
                <div class="card-body p-3">
                    <div class="table-responsive" style="max-height: 70vh">
                        <table class="table table-hover mb-0" id="ticketsTable" style="width:100%">
                            <thead class="bg-light">
                            <tr>
                                <th class="text-start">Ticket #</th>
                                <th class="text-center">Timeline</th>
                                <th class="text-start">Date</th>
                                <th class="text-start">Service</th>
                                <th class="text-start">Tugboat</th>
                                <th class="text-center">Total Hrs</th>
                                <th class="text-end">Billing</th>
                                <th class="text-start">Status</th>
                                <th class="text-center" style="width: 120px;">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var ticket in Model.DispatchTickets!)
                            {
                            <tr>
                                <td class="text-start">
                                    <span class="fw-bold">@ticket.DispatchNumber</span>
                                </td>
                                <td class="text-start small">
                                    @if (ticket.DateLeft.HasValue && ticket.TimeLeft.HasValue && ticket.DateArrived.HasValue && ticket.TimeArrived.HasValue)
                                    {
                                        <span>@ticket.DateLeft.Value.ToString("MMM dd"), @ticket.TimeLeft.Value.ToString("HH:mm")</span>
                                        <span class="text-muted mx-1">→</span>
                                        <span>@ticket.DateArrived.Value.ToString("MMM dd"), @ticket.TimeArrived.Value.ToString("HH:mm")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-start">@(ticket.Date?.ToString("MMM dd, yyyy") ?? "-")</td>
                                <td class="text-start">@ticket.Service?.ServiceName</td>
                                <td class="text-start">@ticket.Tugboat?.TugboatName</td>
                                <td class="text-center">@ticket.TotalHours.ToString("N2")</td>
                                <td class="text-end">₱ @ticket.TotalBilling.ToString("N2")</td>
                                <td class="text-start"><span class="badge rounded-pill" data-status="@ticket.Status">@ticket.Status</span></td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <button type="button" class="btn btn-sm btn-outline-info" title="Quick View"
                                                onclick="showTicketModal(@ticket.DispatchTicketId)">
                                            <i class="bi bi-eye"></i>
                                        </button>

                                        @if (ticket.Status == "For Tariff" || ticket.Status == "Pending")
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary"
                                                    title="Set Tariff"
                                                    onclick="openSetTariffModal(@ticket.DispatchTicketId)">
                                                <i class="bi bi-currency-dollar"></i>
                                            </button>
                                            @if (Model.Status == "Open")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        title="Edit Ticket"
                                                        onclick="openDispatchTicketModal(@ticket.DispatchTicketId)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                            }
                                        }
                                        else if (ticket.Status == "For Approval")
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-success"
                                                    title="Review & Approve"
                                                    onclick="openApprovalModal(@ticket.DispatchTicketId)">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                            @if (Model.Status == "Open")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        title="Edit Ticket"
                                                        onclick="openDispatchTicketModal(@ticket.DispatchTicketId)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                            }
                                        }
                                        else if (ticket.Status == "Disapproved")
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-warning"
                                                    title="Edit Tariff"
                                                    onclick="openEditTariffModal(@ticket.DispatchTicketId)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        }
                                        else if (ticket.Status == "For Billing" || ticket.Status == "Billed")
                                        {
                                            @if (Model.Status == "Open")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        title="Edit Ticket (Warning: Billed)"
                                                        onclick="openDispatchTicketModalWithWarning(@ticket.DispatchTicketId, '@ticket.Status')">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Ticket Details Modal -->
        <div class="modal fade" id="ticketModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content" id="ticketModalContent"></div>
            </div>
        </div>

        <!-- Add / Edit Ticket Modal -->
        <div class="modal fade" id="addTicketModal" tabindex="-1" aria-labelledby="addTicketModalLabel"
             aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title" id="addTicketModalLabel"><i class="bi bi-plus-circle me-2"></i>Add New
                            Dispatch Ticket</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body" id="addTicketModalBody">
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" id="saveTicketBtn"
                                onclick="submitAddTicketForm()"><i class="bi bi-save me-1"></i> Save Ticket
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Edit Job Order Modal -->
        <div class="modal fade" id="editJobOrderModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content" id="editJobOrderModalContent"></div>
            </div>
        </div>

        <!-- Set Tariff Modal -->
        <div class="modal fade" id="setTariffModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content" id="setTariffModalContent"></div>
            </div>
        </div>

        <!-- Edit Tariff Modal -->
        <div class="modal fade" id="editTariffModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content" id="editTariffModalContent"></div>
            </div>
        </div>

        <!-- Tariff Approval Modal -->
        <div class="modal fade" id="tariffApprovalModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content" id="tariffApprovalModalContent"></div>
            </div>
        </div>

        <!-- Disapprove Reason Modal -->
        <div class="modal fade" id="disapproveModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-md">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h6 class="modal-title"><i class="bi bi-exclamation-triangle me-1"></i>Disapprove Tariff</h6>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="disapproveTicketId"/>
                        <div class="mb-3">
                            <label for="disapproveReason" class="form-label fw-bold">Reason <span class="text-danger">*</span></label>
                            <textarea id="disapproveReason" class="form-control" rows="5" required minlength="10"
                                      placeholder="Please provide a detailed reason for disapproval (minimum 10 characters)"></textarea>
                            <div class="invalid-feedback">Please provide a reason (at least 10 characters)</div>
                        </div>
                        <div>
                            <small class="text-muted">Common reasons (click to add):</small>
                            <div class="mt-2">
                                <span class="badge bg-secondary me-1 mb-1" style="cursor: pointer; font-weight: normal;" onclick="addDisapproveReason('Incorrect rate')">Incorrect rate</span>
                                <span class="badge bg-secondary me-1 mb-1" style="cursor: pointer; font-weight: normal;" onclick="addDisapproveReason('Missing documentation')">Missing documentation</span>
                                <span class="badge bg-secondary me-1 mb-1" style="cursor: pointer; font-weight: normal;" onclick="addDisapproveReason('Needs revision')">Needs revision</span>
                                <span class="badge bg-secondary me-1 mb-1" style="cursor: pointer; font-weight: normal;" onclick="addDisapproveReason('Does not match agreed terms')">Does not match agreed terms</span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-danger" onclick="submitDisapproval()">
                            <i class="bi bi-x-circle me-1"></i>Disapprove
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Permission Denied Modal -->
        <div class="modal fade" id="permissionDeniedModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">
                            <i class="bi bi-shield-lock me-2"></i>Access Denied
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <!-- Content will be loaded dynamically -->
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/mmsi/job-order-details.js"></script>
    <script>
        const PageConfig = {
            jobOrderId: @Model.JobOrderId,
            jobOrderNumber: '@Model.JobOrderNumber',
            status: '@Model.Status',
            hasTickets: @(Model.DispatchTickets.Any() ? "true" : "false"),
            messages: {
                error: @(TempData.Peek("error") != null ? $"'{Html.Raw(TempData.Peek("error"))}'" : "null"),
                success: @(TempData.Peek("success") != null ? $"'{TempData.Peek("success")}'" : "null")
            },
            urls: {
                getDispatchTicketPartial: '@Url.Action("GetDispatchTicketPartial", "DispatchTicket")',
                editModal: '@Url.Action("EditModal", "JobOrder")',
                changeTerminal: '@Url.Action("ChangeTerminal", "JobOrder")',
                getTicketDetails: '@Url.Action("GetTicketDetails", "JobOrder")',
                setTariffModal: '@Url.Action("SetTariffModal", "DispatchTicket")',
                editTariffModal: '@Url.Action("EditTariffModal", "DispatchTicket")',
                tariffApprovalModal: '@Url.Action("TariffApprovalModal", "DispatchTicket")',
                approveTariff: '@Url.Action("ApproveTariff", "DispatchTicket")',
                disapproveTariff: '@Url.Action("DisapproveTariff", "DispatchTicket")',
                checkForTariffRate: '@Url.Action("CheckForTariffRate", "DispatchTicket")'
            }
        };
    </script>
}
