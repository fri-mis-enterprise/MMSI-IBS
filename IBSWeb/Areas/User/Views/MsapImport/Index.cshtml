@{
ViewData["Title"] = "MSAP Import";
}

<style>
    .import-file-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid #f0f0f0;
    }

    .import-file-row:last-child {
        border-bottom: none;
    }

    .import-file-label {
        min-width: 140px;
        font-weight: 500;
        font-size: 0.875rem;
        color: #374151;
        flex-shrink: 0;
    }

    .import-file-input {
        flex: 1;
        font-size: 0.8rem;
    }

    .file-badge {
        display: inline-block;
        font-size: 0.7rem;
        padding: 1px 6px;
        border-radius: 4px;
        font-weight: 600;
        letter-spacing: 0.03em;
        flex-shrink: 0;
    }

    .badge-required {
        background: #fef3c7;
        color: #92400e;
        border: 1px solid #fde68a;
    }

    .badge-optional {
        background: #f0fdf4;
        color: #166534;
        border: 1px solid #bbf7d0;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
    }
</style>

<div class="container-fluid mt-4" style="max-width: 900px;">
    <div class="d-flex justify-content-between align-items-center bg-secondary p-3 rounded shadow">
        <h2 class="text-white m-0">@ViewData["Title"]</h2>
    </div>

    <div class="card shadow border-0 mt-3">
        <div class="card-body p-4">
            <p class="text-muted small mb-4">
                Upload CSV files for the data you want to import. Leave a field empty to skip it.
                <strong>Customer CSV is required</strong> when importing Principals, Tariffs, Dispatch Tickets, Billings, or Collections.
            </p>

            <form asp-action="Index" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="row g-4">

                    @* Master Files *@
                    <div class="col-12 col-md-6">
                        <div class="section-header">
                            <h5 class="m-0 fw-semibold">Master Files</h5>
                        </div>
                        <div class="border rounded p-3 bg-light bg-opacity-50">

                            <div class="import-file-row">
                                <span class="import-file-label">Customer</span>
                                <span class="file-badge badge-required">Shared</span>
                                <input type="file" name="customerFile" accept=".csv" class="form-control form-control-sm import-file-input" />
                            </div>

                            <div class="import-file-row">
                                <span class="import-file-label">Port</span>
                                <span class="file-badge badge-optional">Optional</span>
                                <input type="file" name="portFile" accept=".csv" class="form-control form-control-sm import-file-input" />
                            </div>

                            <div class="import-file-row">
                                <span class="import-file-label">Terminal</span>
                                <span class="file-badge badge-optional">Optional</span>
                                <input type="file" name="terminalFile" accept=".csv" class="form-control form-control-sm import-file-input" />
                            </div>

                            <div class="import-file-row">
                                <span class="import-file-label">Principal</span>
                                <span class="file-badge badge-optional">Optional</span>
                                <input type="file" name="principalFile" accept=".csv" class="form-control form-control-sm import-file-input" />
                            </div>

                            <div class="import-file-row">
                                <span class="import-file-label">Service</span>
                                <span class="file-badge badge-optional">Optional</span>
                                <input type="file" name="serviceFile" accept=".csv" class="form-control form-control-sm import-file-input" />
                            </div>

                            <div class="import-file-row">
                                <span class="import-file-label">Tugboat Owner</span>
                                <span class="file-badge badge-optional">Optional</span>
                                <input type="file" name="tugboatOwnerFile" accept=".csv" class="form-control form-control-sm import-file-input" />
                            </div>

                            <div class="import-file-row">
                                <span class="import-file-label">Tugboat</span>
                                <span class="file-badge badge-optional">Optional</span>
                                <input type="file" name="tugboatFile" accept=".csv" class="form-control form-control-sm import-file-input" />
                            </div>

                            <div class="import-file-row">
                                <span class="import-file-label">Tug Master</span>
                                <span class="file-badge badge-optional">Optional</span>
                                <input type="file" name="tugMasterFile" accept=".csv" class="form-control form-control-sm import-file-input" />
                            </div>

                            <div class="import-file-row">
                                <span class="import-file-label">Vessel</span>
                                <span class="file-badge badge-optional">Optional</span>
                                <input type="file" name="vesselFile" accept=".csv" class="form-control form-control-sm import-file-input" />
                            </div>

                        </div>
                    </div>

                    @* Data Entries *@
                    <div class="col-12 col-md-6">
                        <div class="section-header">
                            <h5 class="m-0 fw-semibold">Data Entries</h5>
                        </div>
                        <div class="border rounded p-3 bg-light bg-opacity-50">

                            <div class="import-file-row">
                                <span class="import-file-label">Tariff</span>
                                <span class="file-badge badge-optional">Optional</span>
                                <input type="file" name="tariffFile" accept=".csv" class="form-control form-control-sm import-file-input" />
                            </div>

                            <div class="import-file-row">
                                <span class="import-file-label">Dispatch Ticket</span>
                                <span class="file-badge badge-optional">Optional</span>
                                <input type="file" name="dispatchTicketFile" accept=".csv" class="form-control form-control-sm import-file-input" />
                            </div>

                            <div class="import-file-row">
                                <span class="import-file-label">Billing</span>
                                <span class="file-badge badge-optional">Optional</span>
                                <input type="file" name="billingFile" accept=".csv" class="form-control form-control-sm import-file-input" />
                            </div>

                            <div class="import-file-row">
                                <span class="import-file-label">Collection</span>
                                <span class="file-badge badge-optional">Optional</span>
                                <input type="file" name="collectionFile" accept=".csv" class="form-control form-control-sm import-file-input" />
                            </div>

                        </div>
                    </div>

                </div>

                <div class="mt-4 d-flex align-items-center gap-3">
                    <button class="btn btn-primary px-4" type="submit" id="submitBtn">
                        <i class="bi bi-upload me-1"></i> Import
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="clearAllBtn">
                        Clear All
                    </button>
                    <span class="text-muted small ms-auto" id="fileCount"></span>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(document).ready(function () {
        const allFileInputs = $('input[type="file"]');

        function updateFileCount() {
            const count = allFileInputs.filter(function () { return this.files.length > 0; }).length;
            $('#fileCount').text(count > 0 ? `${count} file${count > 1 ? 's' : ''} selected` : '');
        }

        allFileInputs.on('change', updateFileCount);

        $('#clearAllBtn').on('click', function () {
            allFileInputs.val('');
            updateFileCount();
        });

        $('form').on('submit', function () {
            const anySelected = allFileInputs.filter(function () { return this.files.length > 0; }).length > 0;
            if (!anySelected) {
                alert('Please upload at least one CSV file.');
                return false;
            }
            $('#submitBtn').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Importing...');
        });
    });
</script>
}
